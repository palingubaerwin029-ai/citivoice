# ── Sevalla Production Environment Configuration ──
PORT=5000
NODE_ENV=production

# ── Database (Sevalla Managed MySQL) ────────────────────────
# Fill in connection details provided in your Sevalla Database dashboard
DB_HOST=db-xxxx.sevalla.com
DB_PORT=3306
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=citivoice

# ── App ───────────────────────────────────────────────────────
# The public URL assigned to your Backend Application on Sevalla
BASE_URL=https://citivoice-api.sevalla.com

# ── Security ─────────────────────────────────────────────────
# Generate a secure random key: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_secure_key

# Comma-separated list of allowed origins (your deployed static admin panel & mobile assets)
ALLOWED_ORIGINS=https://citivoice-admin.sevalla.com

# Global rate-limit (number of queries per IP per 15-min window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Gmail SMTP (Nodemailer) ──────────────────────────────────
# Gmail + App Password generated in Google Account security settings
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# ── Groq AI ──────────────────────────────────────────────────
# Groq Console API Key
GROQ_API_KEY=your_groq_api_key
